generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Sem mudanças ─────────────────────────────────────────────────────────────
model Usuario {
  id        Int     @id @default(autoincrement())
  nome      String
  email     String  @unique
  senha     String?
  google_id String? @unique

  personagens Personagem[]
  sessoes     Sessao[]
}

// ─── Personagem — modelo central, simplificado ────────────────────────────────
// Removido: pontos_poder_gastos, relações com Atributo/Poder/Pericia/Vantagem/Complicacao
// Adicionado: campos de texto livre + defesas estruturadas + metadados de imagem
model Personagem {
  id               Int     @id @default(autoincrement())
  nome             String
  foto             String? // URL da foto no Cloudinary (mantido)
  tipo             String  // 'jogador' ou 'npc'
  machucados       Int     @default(0)
  owlbear_token_id String? // preparado para integração futura

  usuario_id Int
  usuario    Usuario @relation(fields: [usuario_id], references: [id])

  // Defesas estruturadas — o sistema usa em combate (Painel do Mestre, rolagens)
  esquiva      Int @default(0)
  aparar       Int @default(0)
  fortitude    Int @default(0)
  resistencia  Int @default(0)
  vontade      Int @default(0)

  // Atributos — mantidos como campos diretos (sem tabela separada)
  forca       Int @default(0)
  agilidade   Int @default(0)
  luta        Int @default(0)
  vigor       Int @default(0)
  destreza    Int @default(0)
  intelecto   Int @default(0)
  consciencia Int @default(0)
  presenca    Int @default(0)

  // Campos de texto livre — o jogador escreve como quiser
  // O frontend faz preview ao vivo; o banco guarda o texto bruto
  poderes_texto     String? @db.Text
  pericias_texto    String? @db.Text
  vantagens_texto   String? @db.Text
  equipamentos_texto String? @db.Text
  complicacoes_texto String? @db.Text
  citacao           String? @db.Text

  // Pericias parseadas — array JSON gerado automaticamente pelo backend
  // a partir de pericias_texto para permitir rolagens no Painel do Mestre
  // Formato: [{"nome": "Atletismo", "bonus": 6}, {"nome": "Tecnologia", "bonus": 17}]
  pericias_parsed Json? @default("[]")

  // Metadados da imagem de fundo — controle de posição e zoom
  // Formato: {"x": 50, "y": 30, "zoom": 1.2}
  // x e y são percentuais (object-position), zoom é o scale
  imagem_posicao Json? @default("{\"x\": 50, \"y\": 20, \"zoom\": 1.0}")

  // Backup completo da ficha para exportação/importação de PDF
  // Guarda todos os campos em JSON para recriar a ficha do zero
  ficha_snapshot Json?

  sessoes SessaoPersonagem[]
}

// ─── Sessao — sem mudanças ────────────────────────────────────────────────────
model Sessao {
  id          Int      @id @default(autoincrement())
  nome        String
  data        DateTime @default(now())
  nivel_poder Int      @default(10)
  codigo      String   @unique @default(cuid())
  mestre_id   Int

  jogadores_podem_alterar_machucados Boolean @default(false)
  jogadores_podem_editar_ficha       Boolean @default(false)

  mestre      Usuario          @relation(fields: [mestre_id], references: [id])
  personagens SessaoPersonagem[]
}

// ─── SessaoPersonagem — sem mudanças ─────────────────────────────────────────
model SessaoPersonagem {
  sessao_id     Int
  personagem_id Int
  em_cena       Boolean @default(false)

  sessao     Sessao     @relation(fields: [sessao_id], references: [id])
  personagem Personagem @relation(fields: [personagem_id], references: [id])

  @@id([sessao_id, personagem_id])
}

// ─── Tabelas removidas ────────────────────────────────────────────────────────
// Atributo            → virou campos diretos no Personagem
// Poder               → não existe mais (era biblioteca de poderes do banco)
// PersonagemPoder     → não existe mais
// PersonagemPericia   → virou pericias_texto + pericias_parsed no Personagem
// PersonagemVantagem  → virou vantagens_texto no Personagem
// PersonagemComplicacao → virou complicacoes_texto no Personagem
